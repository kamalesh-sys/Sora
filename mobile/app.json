{
  "expo": {
    "name": "Sora Expense",
    "slug": "sora-expense",
    "version": "1.0.0",
    "icon": "./src/assets/sora_og_logo.png",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "soraexpense",
    "jsEngine": "hermes",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./src/assets/sora_og_logo.png"
    },
    "android": {
      "package": "com.soraexpense.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/sora_og_logo.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#FFFFFF",
          "barStyle": "dark",
          "behavior": "inset-touch",
          "borderColor": "#FFFFFF",
          "position": "relative",
          "visibility": "visible"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SoraExpense",
              "label": "Sora Expense",
              "description": "Recent expense and quick add",
              "minWidth": "250dp",
              "minHeight": "96dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-audio",
      "expo-localization"
    ]
  }
}
